<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.maple.launcher.ui.AccountsController" spacing="15" styleClass="page">
    <Label text="Accounts" styleClass="page-title"/>

    <HBox spacing="10">
        <TextField fx:id="offlineUserField" promptText="Offline Username" styleClass="input"/>
        <Button text="Add Offline" onAction="#onAddOffline" styleClass="btn-primary"/>
        <Button text="Add Premium (Microsoft)" onAction="#onAddPremium" styleClass="btn-primary"/>
    </HBox>

    <ListView fx:id="accountList" VBox.vgrow="ALWAYS" styleClass="list"/>

    <HBox spacing="10">
        <Button fx:id="useSelectedBtn" text="Use Selected" onAction="#onUseSelected" styleClass="btn-secondary"/>
        <Button fx:id="deleteBtn" text="Delete Selected" onAction="#onDelete" styleClass="btn-danger"/>
    </HBox>
</VBox>